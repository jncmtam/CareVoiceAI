# CareVoice AI — copy thành .env và điền giá trị thật (KHÔNG commit .env)
# cp .env.example .env

APP_ENV=local
APP_NAME="CareVoice AI API"
API_V1_PREFIX=/api/v1

# SQLite local (mặc định). Docker dùng PostgreSQL — xem docker-compose.yml
DATABASE_URL=sqlite+aiosqlite:///./carevoice.db
AUTO_CREATE_TABLES=true
SEED_DEMO_DATA=true

JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_SECONDS=3600
REFRESH_TOKEN_EXPIRE_DAYS=30

CORS_ORIGINS=["http://127.0.0.1:8000","http://localhost:8000"]
MEDIA_BASE_URL=http://127.0.0.1:8000
LOCAL_STORAGE_DIR=./storage

# true = mock VNPT (demo nhanh, không cần credential)
# false = gọi VNPT thật (cần điền token bên dưới)
VENDOR_MOCK_MODE=true

REQUEST_TIMEOUT_SECONDS=30
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60

# --- VNPT (chỉ khi VENDOR_MOCK_MODE=false) ---
VNPT_IDG_BASE_URL=https://api.idg.vnpt.vn
VNPT_SMARTBOT_BASE_URL=https://assistant-stream.vnpt.vn

VNPT_OAUTH_USERNAME=
VNPT_OAUTH_PASSWORD=
VNPT_OAUTH_CLIENT_ID=
VNPT_OAUTH_CLIENT_SECRET=

VNPT_TOKEN_ID=
VNPT_TOKEN_KEY=
VNPT_ACCESS_TOKEN=

VNPT_SMARTREADER_TOKEN_ID=
VNPT_SMARTREADER_TOKEN_KEY=
VNPT_SMARTREADER_ACCESS_TOKEN=

VNPT_TTS_TOKEN_ID=
VNPT_TTS_TOKEN_KEY=
VNPT_TTS_ACCESS_TOKEN=

VNPT_STT_TOKEN_ID=
VNPT_STT_TOKEN_KEY=
VNPT_STT_ACCESS_TOKEN=

VNPT_SMARTBOT_TOKEN_ID=
VNPT_SMARTBOT_TOKEN_KEY=
VNPT_SMARTBOT_ACCESS_TOKEN=
VNPT_SMARTBOT_BOT_ID=
VNPT_SMARTBOT_INPUT_CHANNEL=livechat

VNPT_MAC_ADDRESS=carevoice-api-client-001
VNPT_CLIENT_SESSION=carevoice-session
VNPT_CLIENT_TOKEN=carevoice-client-token

VNPT_OCR_JOB_TIMEOUT_SECONDS=120
VNPT_OCR_POLL_INTERVAL_SECONDS=2
VNPT_TTS_MODEL=news
VNPT_TTS_SPEED=1
VNPT_TTS_REGION=female_north
VNPT_TTS_FORMAT=mp3
VNPT_STT_ASYNC_DURATION_THRESHOLD_SECONDS=30
VNPT_STT_JOB_TIMEOUT_SECONDS=120
VNPT_STT_POLL_INTERVAL_SECONDS=2

REDIS_URL=redis://localhost:6379/0